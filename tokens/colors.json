{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "50":  { "$value": "#FDF8F0", "$type": "color" },
      "100": { "$value": "#FAF0E0", "$type": "color" },
      "200": { "$value": "#F4DFC0", "$type": "color" },
      "300": { "$value": "#E8C494", "$type": "color" },
      "400": { "$value": "#DCA458", "$type": "color" },
      "500": { "$value": "#D08C30", "$type": "color" },
      "600": { "$value": "#B87420", "$type": "color" },
      "700": { "$value": "#8C5818", "$type": "color" },
      "800": { "$value": "#6A4214", "$type": "color" },
      "900": { "$value": "#3C2610", "$type": "color" },
      "950": { "$value": "#241608", "$type": "color" }
    },
    "accent": {
      "primary": { "$value": "#E08A30", "$type": "color" },
      "fg":      { "$value": "#FFFFFF", "$type": "color" }
    },
    "neutral": {
      "0":   { "$value": "#FFFFFF", "$type": "color" },
      "50":  { "$value": "#F8F6F3", "$type": "color" },
      "100": { "$value": "#F0ECE6", "$type": "color" },
      "200": { "$value": "#E0D8CE", "$type": "color" },
      "300": { "$value": "#C8BEB0", "$type": "color" },
      "400": { "$value": "#A89E90", "$type": "color" },
      "500": { "$value": "#807668", "$type": "color" },
      "600": { "$value": "#5E564C", "$type": "color" },
      "700": { "$value": "#443E36", "$type": "color" },
      "800": { "$value": "#2E2A24", "$type": "color" },
      "900": { "$value": "#1C1A16", "$type": "color" }
    },
    "semantic": {
      "bg": {
        "surface":    { "$value": "{color.neutral.0}", "$type": "color" },
        "muted":      { "$value": "{color.neutral.50}", "$type": "color" }
      },
      "text": {
        "primary":    { "$value": "{color.neutral.900}", "$type": "color" },
        "muted":      { "$value": "{color.neutral.500}", "$type": "color" }
      },
      "border": {
        "default":    { "$value": "{color.neutral.200}", "$type": "color" }
      }
    }
  }
}
